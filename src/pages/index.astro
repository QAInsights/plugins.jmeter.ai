---
import '../styles/global.css';
import pluginsData from '../data/plugins_data.json';
import PluginCard from '../components/PluginCard.astro';

// Sort descending by trending delta for "Hot This Week"
const trendingPlugins = [...pluginsData]
  .sort((a, b) => b.stats.trendingDelta - a.stats.trendingDelta)
  .slice(0, 3);

// Get Featured Plugins
const featuredPlugins = pluginsData.filter(p => p.isFeatured);

// Extract Unique Categories for Filters
const categoriesSet = new Set(['All']);
pluginsData.forEach(p => {
  let cat = 'Others';
  if (p.componentClasses) {
    const classesStr = p.componentClasses.join(' ').toLowerCase();
    if (classesStr.includes('assertion')) cat = 'Assertions';
    else if (classesStr.includes('listener') || classesStr.includes('visualizer')) cat = 'Listeners';
    else if (classesStr.includes('sampler')) cat = 'Samplers';
    else if (classesStr.includes('config')) cat = 'Configs';
    else if (classesStr.includes('timer')) cat = 'Timers';
    else if (classesStr.includes('processor')) cat = 'Processors';
  }
  if (cat !== 'Others') categoriesSet.add(cat);
});
categoriesSet.add('Others');
const categories = Array.from(categoriesSet);

---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>PerfAtlas - The Modern JMeter Directory</title>
        <meta name="description" content="Discover, search, and track modern and AI-ready JMeter plugins. Community-driven directory automatically synced daily." />

        <script>
            // Inline script to prevent flash of wrong theme
            if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        </script>
	</head>
	<body class="min-h-screen flex flex-col font-sans antialiased overflow-x-hidden selection:bg-primary dark:selection:bg-[#ccff00] selection:text-white dark:selection:text-dark-bg">
		
        {/* Header */}
        <header class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-white/10 bg-white/80 dark:bg-dark-bg/80 backdrop-blur-md">
            <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-secondary flex items-center justify-center font-bold text-white shadow-md shadow-primary/20 dark:shadow-[0_0_15px_rgba(204,255,0,0.3)]">
                        P
                    </div>
                    <span class="text-xl font-extrabold tracking-tight text-gray-900 dark:text-white">Perf<span class="text-primary dark:text-[#ccff00]">Atlas</span></span>
                </div>

                <div class="flex items-center gap-6 text-sm font-medium text-gray-600 dark:text-gray-400">
                    <button id="themeToggle" class="p-2 rounded-lg bg-gray-100 dark:bg-dark-surface border border-gray-200 dark:border-white/10 hover:bg-gray-200 dark:hover:bg-white/5 transition-colors">
                        <svg id="themeIconDark" class="w-4 h-4 hidden dark:block text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                        <svg id="themeIconLight" class="w-4 h-4 block dark:hidden text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                    </button>
                </div>
            </div>
        </header>

        <main class="flex-grow flex flex-col">
            
            {/* Hero Section */}
            <section class="relative pt-24 pb-16 px-6 border-b border-gray-200 dark:border-white/5 overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/5 via-transparent to-transparent pointer-events-none"></div>
                <div class="max-w-4xl mx-auto text-center relative z-10">
                    <h1 class="text-5xl md:text-6xl font-black mb-6 leading-tight tracking-tight text-gray-900 dark:text-white">
                        Power up <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">JMeter</span> with AI.
                    </h1>
                    <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed">
                        The ultimate directory for modern load testing. Search, discover, and track the velocity of the best plugins, completely synced daily.
                    </p>

                    {/* Search Bar */}
                    <div class="relative max-w-2xl mx-auto group">
                        <div class="absolute -inset-1 bg-gradient-to-r from-primary to-secondary rounded-xl blur opacity-15 group-focus-within:opacity-40 transition duration-500"></div>
                        <div class="relative flex items-center bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 rounded-xl overflow-hidden shadow-xl">
                            <span class="pl-5 text-gray-400 dark:text-white/40 group-focus-within:text-primary transition-colors">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </span>
                            <input 
                                type="text" 
                                id="searchInput"
                                placeholder="Search plugins by name, description, or class..." 
                                class="w-full bg-transparent text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-white/40 px-4 py-5 outline-none font-medium text-lg"
                            />
                        </div>
                    </div>
                </div>
            </section>

            {/* Featured & Trending Section */}
            <section id="featuredTrendingSection" class="py-16 px-6 bg-gray-50/50 dark:bg-white/[0.01] transition-all duration-300">
                <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
                    
                    {/* Featured Placeholder */}
                    <div class="flex flex-col">
                        <div class="flex items-center gap-3 mb-8">
                            <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                            <h2 class="text-2xl font-bold dark:text-white">Featured</h2>
                        </div>
                        
                        <a href="mailto:support@qainsights.com?subject=Feature my JMeter Plugin" class="flex-grow border-2 border-dashed border-gray-300 dark:border-white/20 rounded-xl flex flex-col items-center justify-center p-8 text-center bg-white dark:bg-dark-surface/50 hover:bg-gray-50 dark:hover:bg-white/5 transition-colors cursor-pointer group min-h-[200px]">
                            <div class="w-12 h-12 rounded-full bg-purple-100 dark:bg-purple-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                            </div>
                            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Feature Your Plugin</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400 max-w-sm">Want to reach thousands of JMeter users? Promote your plugin here across the ecosystem.</p>
                        </a>
                    </div>

                    {/* Trending */}
                    <div class="flex flex-col">
                        <div class="flex items-center gap-3 mb-8">
                            <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                            <h2 class="text-2xl font-bold dark:text-white">Hot This Week</h2>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6 flex-grow">
                            {trendingPlugins.slice(0, 2).map(plugin => (
                                <PluginCard plugin={plugin} />
                            ))}
                        </div>
                    </div>
                </div>
            </section>

            {/* All Plugins Grid with Filters */}
            <section class="py-16 px-6 flex-grow">
                <div class="max-w-7xl mx-auto">
                    
                    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
                        <div>
                            <h2 class="text-2xl font-bold dark:text-white mb-4">All Directory Plugins</h2>
                            
                            {/* Filter Categories */}
                            <div class="flex flex-wrap gap-2" id="categoryFilters">
                                {categories.map((cat, index) => (
                                    <button 
                                        data-filter={cat.toLowerCase()} 
                                        class={`filter-btn px-4 py-1.5 rounded-full text-sm font-semibold transition-all border
                                        ${index === 0 
                                            ? 'bg-primary border-primary text-gray-900 shadow-md' 
                                            : 'bg-white dark:bg-dark-surface border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-300 hover:border-primary/50'
                                        }`}
                                    >
                                        {cat}
                                    </button>
                                ))}
                            </div>
                        </div>
                        
                        <span class="text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-white/10 px-3 py-1 rounded-full text-sm font-bold shrink-0" id="resultCount">{pluginsData.length} plugins</span>
                    </div>

                    <div id="noResults" class="hidden text-center py-20 border border-gray-200 dark:border-white/5 rounded-2xl bg-gray-50 dark:bg-white/[0.01]">
                        <h3 class="text-xl text-gray-500 dark:text-gray-400">No plugins found matching your criteria.</h3>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="pluginGrid">
                        {pluginsData.map(plugin => (
                            <div class="plugin-wrapper" 
                                 data-name={plugin.name.toLowerCase()} 
                                 data-desc={plugin.description.toLowerCase()} 
                                 data-vendor={plugin.vendor.toLowerCase()}
                                 data-category={
                                    (() => {
                                        let c = 'others';
                                        if (plugin.componentClasses) {
                                            const str = plugin.componentClasses.join(' ').toLowerCase();
                                            if (str.includes('assertion')) c = 'assertions';
                                            else if (str.includes('listener') || str.includes('visualizer')) c = 'listeners';
                                            else if (str.includes('sampler')) c = 'samplers';
                                            else if (str.includes('config')) c = 'configs';
                                            else if (str.includes('timer')) c = 'timers';
                                            else if (str.includes('processor')) c = 'processors';
                                        }
                                        return c;
                                    })()
                                 }
                            >
                                <PluginCard plugin={plugin} />
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        </main>

        <footer class="border-t border-gray-200 dark:border-white/10 py-12 px-6 mt-auto bg-gray-50 dark:bg-transparent">
            <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-sm text-gray-500 dark:text-gray-400">
                <p>&copy; {new Date().getFullYear()} PerfAtlas. Directory synced from jmeter-plugins.org.</p>
                <div class="flex gap-6">
                    <span class="flex items-center gap-2">Built with <span class="text-primary-dark dark:text-[#ccff00] font-bold">Astro</span> & <span class="text-secondary font-bold">Tailwind</span></span>
                </div>
            </div>
        </footer>

        {/* Plugin Details Modal */}
        <dialog id="pluginModal" class="m-auto backdrop:bg-black/70 backdrop:backdrop-blur-sm bg-transparent p-4 md:p-6 w-full max-w-3xl border-none outline-none overflow-visible">
            <div class="relative bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 rounded-2xl shadow-2xl flex flex-col max-h-[90vh] overflow-hidden">
                <div class="flex items-start justify-between p-6 border-b border-gray-100 dark:border-white/10 relative">
                    <div id="modalHeaderBg" class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary hidden"></div>
                    <div>
                        <h2 id="modalTitle" class="text-2xl font-bold text-gray-900 dark:text-white leading-tight pr-8"></h2>
                        <p id="modalVendor" class="text-sm font-semibold text-gray-500 dark:text-gray-400 mt-1 uppercase tracking-widest"></p>
                    </div>
                    <button id="modalClose" class="absolute top-6 right-6 p-2 rounded-lg bg-gray-100 dark:bg-white/5 text-gray-500 hover:text-gray-900 dark:hover:text-white hover:bg-gray-200 dark:hover:bg-white/10 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                <div class="p-6 overflow-y-auto flex-grow flex flex-col gap-6 text-gray-700 dark:text-gray-300">
                    <p id="modalDescription" class="text-base leading-relaxed"></p>
                    <div id="modalClassesWrapper">
                        <h4 class="text-sm font-bold text-gray-900 dark:text-white mb-2 uppercase tracking-wide">Component Classes</h4>
                        <div id="modalClasses" class="bg-gray-50 dark:bg-black/20 rounded-lg p-4 font-mono text-xs overflow-x-auto border border-gray-100 dark:border-white/5 max-h-48 overflow-y-auto leading-loose whitespace-pre"></div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-gray-50 dark:bg-black/20 rounded-lg p-4 border border-gray-100 dark:border-white/5">
                            <h4 class="text-xs font-bold text-gray-500 uppercase mb-1">Total Downloads</h4>
                            <p id="modalDownloads" class="text-xl font-bold text-gray-900 dark:text-white"></p>
                        </div>
                        <div class="bg-gray-50 dark:bg-black/20 rounded-lg p-4 border border-gray-100 dark:border-white/5">
                            <h4 class="text-xs font-bold text-gray-500 uppercase mb-1">Downloads This Week</h4>
                            <p id="modalTrending" class="text-xl font-bold"></p>
                        </div>
                    </div>
                </div>
                <div class="p-6 border-t border-gray-100 dark:border-white/10 flex justify-end gap-4 bg-gray-50 dark:bg-white/[0.02]">
                    <a id="modalLink" href="#" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 rounded-lg bg-gray-900 dark:bg-white text-white dark:text-dark-bg font-bold hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors shadow-lg flex items-center gap-2">
                        View Plugin Repository
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                    </a>
                </div>
            </div>
        </dialog>

        {/* Client-side logic for Theme and Searching/Filtering */}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                // Theme Toggle Logic
                const themeToggle = document.getElementById('themeToggle');
                themeToggle.addEventListener('click', () => {
                    if (document.documentElement.classList.contains('dark')) {
                        document.documentElement.classList.remove('dark');
                        localStorage.theme = 'light';
                    } else {
                        document.documentElement.classList.add('dark');
                        localStorage.theme = 'dark';
                    }
                });

                // Search and Filter Logic
                const searchInput = document.getElementById('searchInput');
                const pluginWrappers = document.querySelectorAll('.plugin-wrapper');
                const noResults = document.getElementById('noResults');
                const resultCount = document.getElementById('resultCount');
                const filterBtns = document.querySelectorAll('.filter-btn');
                const featuredTrendingSection = document.getElementById('featuredTrendingSection');
                
                let currentSearchTerm = '';
                let currentCategory = 'all';

                function updateGrid() {
                    let visibleCount = 0;

                    // Hide Featured/Trending if user is actively searching or filtering
                    if (currentSearchTerm !== '' || currentCategory !== 'all') {
                        featuredTrendingSection.classList.add('hidden');
                    } else {
                        featuredTrendingSection.classList.remove('hidden');
                    }

                    pluginWrappers.forEach(wrapper => {
                        const name = wrapper.getAttribute('data-name');
                        const desc = wrapper.getAttribute('data-desc');
                        const vendor = wrapper.getAttribute('data-vendor');
                        const cat = wrapper.getAttribute('data-category');

                        const matchesSearch = name.includes(currentSearchTerm) || desc.includes(currentSearchTerm) || vendor.includes(currentSearchTerm);
                        const matchesCategory = currentCategory === 'all' || cat === currentCategory;

                        if (matchesSearch && matchesCategory) {
                            wrapper.classList.remove('hidden');
                            visibleCount++;
                        } else {
                            wrapper.classList.add('hidden');
                        }
                    });

                    resultCount.textContent = `${visibleCount} plugin${visibleCount !== 1 ? 's' : ''}`;
                    if (visibleCount === 0) {
                        noResults.classList.remove('hidden');
                    } else {
                        noResults.classList.add('hidden');
                    }
                }

                if (searchInput) {
                    searchInput.addEventListener('input', (e) => {
                        currentSearchTerm = e.target.value.toLowerCase().trim();
                        updateGrid();
                    });
                }

                filterBtns.forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        // Reset all buttons
                        filterBtns.forEach(b => {
                            b.classList.remove('bg-primary', 'border-primary', 'text-gray-900', 'shadow-md');
                            b.classList.add('bg-white', 'dark:bg-dark-surface', 'border-gray-200', 'dark:border-white/10', 'text-gray-600', 'dark:text-gray-300');
                        });
                        
                        // Set active button
                        const target = e.currentTarget;
                        target.classList.remove('bg-white', 'dark:bg-dark-surface', 'border-gray-200', 'dark:border-white/10', 'text-gray-600', 'dark:text-gray-300');
                        target.classList.add('bg-primary', 'border-primary', 'text-gray-900', 'shadow-md');

                        currentCategory = target.getAttribute('data-filter');
                        updateGrid();
                    });
                });

                // Modal Logic
                const modal = document.getElementById('pluginModal');
                const closeBtn = document.getElementById('modalClose');

                closeBtn.addEventListener('click', () => modal.close());
                modal.addEventListener('click', (e) => {
                    if (e.target === modal) modal.close();
                });
                
                modal.addEventListener('close', () => {
                    document.body.style.overflow = 'auto'; // restore scrolling
                });

                document.querySelectorAll('.plugin-card').forEach(card => {
                    card.addEventListener('click', () => {
                        const p = JSON.parse(card.getAttribute('data-plugin'));
                        
                        document.getElementById('modalTitle').textContent = p.name;
                        document.getElementById('modalVendor').textContent = `By ${p.vendor}`;
                        document.getElementById('modalDescription').textContent = p.description;
                        document.getElementById('modalLink').href = p.helpUrl;
                        
                        const classWrapper = document.getElementById('modalClassesWrapper');
                        const classContainer = document.getElementById('modalClasses');
                        if (p.componentClasses && p.componentClasses.length) {
                            classContainer.textContent = p.componentClasses.join('\n');
                            classWrapper.style.display = 'block';
                        } else {
                            classWrapper.style.display = 'none';
                        }

                        document.getElementById('modalDownloads').textContent = new Intl.NumberFormat('en-US').format(p.stats.absoluteDownloads);
                        
                        const trendEl = document.getElementById('modalTrending');
                        const arrow = p.stats.trendingDelta > 0 ? '+' : '';
                        trendEl.textContent = `${arrow}${new Intl.NumberFormat('en-US').format(p.stats.trendingDelta)}`;
                        trendEl.className = `text-xl font-bold ${p.stats.trendingDelta > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-500'}`;

                        const headerBg = document.getElementById('modalHeaderBg');
                        if (p.isFeatured || p.sponsored) {
                            headerBg.classList.remove('hidden');
                        } else {
                            headerBg.classList.add('hidden');
                        }

                        document.body.style.overflow = 'hidden'; // prevent bg scroll
                        modal.showModal();
                    });
                });

            });
        </script>
	</body>
</html>
