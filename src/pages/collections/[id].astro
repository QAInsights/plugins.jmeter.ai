---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CollectionCard from '../../components/CollectionCard.astro';
import CollectionInstallBlock from '../../components/CollectionInstallBlock.astro';
import CollectionPluginRow from '../../components/CollectionPluginRow.astro';
import pluginsData from '../../data/plugins_data.json';
import rawCollections from '../../data/collections.json';
import {
  getCollections,
  getCollectionById,
  getRelatedCollections,
  getCollectionSummaries,
  buildInstallCommand,
} from '../../utils/collection';

export async function getStaticPaths() {
  const collections = getCollections(pluginsData as any[], rawCollections as any[]);
  return collections.map((col) => ({
    params: { id: col.id },
    props: { collection: col, allCollections: collections },
  }));
}

const { collection, allCollections } = Astro.props;

const relatedCollections = getRelatedCollections(collection, allCollections, 3);
const relatedSummaries = getCollectionSummaries(relatedCollections);

const pluginIds = collection.plugins.map((p: any) => p.id);

const formatNumber = (n: number) => new Intl.NumberFormat('en-US').format(n);

const title = `${collection.name} | PerfAtlas Collections`;
const description = `${collection.tagline} Curated by ${collection.curator.name}, ${collection.curator.org}. ${collection.pluginCount} plugins, ${formatNumber(collection.totalDownloads)} total downloads.`;
const ogImage = `/og/collections/${collection.id}.png`;
---

<Layout title={title} description={description} image={ogImage}>
  <Header />
  <main class="flex-grow flex flex-col py-8 sm:py-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto w-full">

      {/* Back Link */}
      <a href="/collections" class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-900 dark:hover:text-white mb-8 transition-colors text-sm font-semibold">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        All Collections
      </a>

      {/* Header Card */}
      <div class="bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 rounded-2xl shadow-xl overflow-hidden mb-8">
        <div class="h-1 bg-gradient-to-r from-primary to-secondary"></div>
        <div class="p-6 sm:p-10">

          <div class="flex flex-col md:flex-row md:items-start justify-between gap-6 mb-6">
            <div class="flex items-start gap-4">
              <span class="text-5xl leading-none" aria-hidden="true">{collection.emoji}</span>
              <div>
                <h1 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white leading-tight tracking-tight mb-1">
                  {collection.name}
                </h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-semibold">
                  {collection.tagline}
                </p>
              </div>
            </div>

            {/* Curator Badge */}
            <a
              href={collection.curator.url}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 hover:border-primary/50 transition-colors text-xs font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap"
            >
              <svg class="w-4 h-4 text-primary dark:text-[#ccff00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              By {collection.curator.name}, {collection.curator.org}
            </a>
          </div>

          <p class="text-base text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
            {collection.description}
          </p>

          {/* Stats */}
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            <div class="bg-gray-50 dark:bg-black/20 rounded-xl p-5 border border-gray-100 dark:border-white/5">
              <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wide mb-1">Plugins in Stack</h4>
              <p class="text-2xl font-black text-gray-900 dark:text-white">{collection.pluginCount}</p>
            </div>
            <div class="bg-gray-50 dark:bg-black/20 rounded-xl p-5 border border-gray-100 dark:border-white/5">
              <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wide mb-1">Total Downloads</h4>
              <p class="text-2xl font-black text-gray-900 dark:text-white">{formatNumber(collection.totalDownloads)}</p>
            </div>
            <div class="bg-gray-50 dark:bg-black/20 rounded-xl p-5 border border-gray-100 dark:border-white/5">
              <h4 class="text-[10px] font-bold text-gray-500 uppercase tracking-wide mb-1">Trending This Week</h4>
              <p class={`text-2xl font-black ${collection.totalTrending >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-500'}`}>
                {collection.totalTrending >= 0 ? '+' : ''}{formatNumber(collection.totalTrending)}
              </p>
            </div>
          </div>

          {/* Install Section */}
          <div class="mb-2">
            <h2 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-widest mb-3">
              Install entire stack
            </h2>
            <CollectionInstallBlock pluginIds={pluginIds} collectionName={collection.name} />
          </div>

        </div>
      </div>

      {/* Plugin List */}
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">
          Plugins in this stack
        </h2>

        <div class="flex flex-col gap-6">
          {collection.plugins.map((plugin: any) => (
            <CollectionPluginRow
              plugin={plugin}
              reason={collection.reasons[plugin.id]}
            />
          ))}
        </div>
      </section>

      {/* Related Collections */}
      {relatedSummaries.length > 0 && (
        <section class="border-t border-gray-100 dark:border-white/10 pt-10">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Related Collections</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {relatedSummaries.map((rel) => (
              <CollectionCard collection={rel} />
            ))}
          </div>
        </section>
      )}

    </div>
  </main>
  <Footer />
</Layout>
