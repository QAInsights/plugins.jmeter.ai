---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { sortPosts, filterDrafts, getReadingTime } from '../../utils/blog';
import Search from 'astro-pagefind/components/Search';

const allPosts = await getCollection('blog');
const posts = sortPosts(filterDrafts(allPosts));
---

<Layout title="Blog - PerfAtlas" description="Insights, tutorials, and updates on the best JMeter plugins and performance engineering techniques.">
    <Header />
    
    <!-- Hero Header with Grid -->
    <section class="relative bg-dark-bg border-b border-white/5 pt-16 pb-24 overflow-hidden">
        <div class="absolute inset-0 grid-background opacity-20"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-dark-bg/80"></div>
        
        <div class="relative max-w-7xl mx-auto px-6 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-white mb-6">
                Welcome, <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-[#ccff00]">world</span>
            </h1>
            <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
                Deep dives into the PerfAtlas ecosystem. Get the latest engineering insights from the JMeter community.
            </p>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-6 py-16 flex-grow w-full">
        <div class="flex flex-col lg:flex-row gap-16">
            <!-- Sidebar -->
            <aside class="w-full lg:w-72 shrink-0">
                <div class="sticky top-24">
                    <div class="sidebar-item">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-6">Search</h3>
                        <Search 
                            id="search" 
                            className="pagefind-ui-custom" 
                            uiOptions={{ showImages: false }}
                        />
                    </div>

                    <div class="sidebar-item">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-6">Popular Tags</h3>
                        <div class="flex flex-wrap gap-2">
                            {Array.from(new Set(posts.flatMap(p => p.data.tags || []))).slice(0, 10).map(tag => (
                                <a href={`/blog/tags/${tag}`} class="px-3 py-1 text-xs font-medium rounded-full bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-[#ccff00]/50 transition-all lowercase">
                                    #{tag}
                                </a>
                            ))}
                        </div>
                    </div>

                    <div class="sidebar-item">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-6">Subscribe</h3>
                        <p class="text-sm text-gray-400 mb-6 leading-relaxed">Stay up-to-date with the latest JMeter plugins and performance news.</p>
                        <a href="/rss.xml" class="flex items-center gap-2 px-4 py-2 bg-white text-black font-bold rounded-lg hover:bg-[#ccff00] transition-colors w-full justify-center">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 19H15V17H19C19.55 17 20 16.55 20 16V5C20 4.45 19.55 4 19 4H5C4.45 4 4 4.45 4 5V9H2V5C2 3.34 3.34 2 5 2H19C20.66 2 22 3.34 22 5V16C22 17.66 20.66 19 19 19M1 17C1 18.66 2.34 20 4 20H15V22H4C1.24 22 0 20.76 0 18V14C0 11.24 1.24 10 4 10H8V12H4C2.34 12 1 13.34 1 15V17M13 13V15H9V13H13Z"/></svg>
                            RSS Feed
                        </a>
                    </div>
                </div>
            </aside>

            <!-- Main Feed -->
            <div class="flex-1">
                <div class="grid grid-cols-1 gap-12">
                    {posts.map((post) => (
                        <article class="group relative flex flex-col md:flex-row gap-8 items-start hover:bg-white/5 p-4 rounded-2xl transition-all duration-300">
                            <a href={`/blog/${post.id}`} class="w-full md:w-80 shrink-0 aspect-video rounded-xl overflow-hidden border border-white/10 relative">
                                {post.data.image ? (
                                    <Image 
                                        src={post.data.image} 
                                        alt={post.data.imageAlt || post.data.title}
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                        width={600}
                                        height={338}
                                        format="webp"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-white/5 flex items-center justify-center">
                                        <span class="text-gray-600">No Image</span>
                                    </div>
                                )}
                                {post.data.featured && (
                                    <div class="absolute top-4 left-4 bg-[#ccff00] text-black text-[10px] font-black px-2 py-1 rounded uppercase tracking-tighter">
                                        Featured
                                    </div>
                                )}
                            </a>
                            
                            <div class="flex-1 flex flex-col pt-2">
                                <time datetime={post.data.pubDate.toISOString()} class="text-[11px] font-mono text-gray-500 uppercase tracking-widest mb-4 block">
                                    {post.data.pubDate.toLocaleDateString('en-US', {
                                        year: 'numeric',
                                        month: 'long',
                                        day: 'numeric',
                                    })}
                                    <span class="mx-2 text-gray-800">•</span>
                                    {getReadingTime(post.body || '')}
                                </time>
                                
                                <h2 class="text-2xl font-bold text-white mb-4 group-hover:text-[#ccff00] transition-colors leading-tight">
                                    <a href={`/blog/${post.id}`}>
                                        {post.data.title}
                                    </a>
                                </h2>
                                
                                <p class="text-gray-400 text-sm leading-relaxed mb-6 line-clamp-3">
                                    {post.data.description}
                                </p>
                                
                                <div class="mt-auto flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-[#ccff00] flex items-center justify-center text-[10px] text-black font-black">
                                            {post.data.author.charAt(0)}
                                        </div>
                                        <span class="text-xs text-gray-300 font-medium">{post.data.author}</span>
                                    </div>
                                    <a href={`/blog/${post.id}`} class="text-[#ccff00] opacity-0 group-hover:opacity-100 transition-all flex items-center gap-1 text-xs font-bold uppercase tracking-widest">
                                        Read Post <svg class="w-3 h-3 translate-y-[-1px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                    </a>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </div>
    </main>
    <Footer />
</Layout>
