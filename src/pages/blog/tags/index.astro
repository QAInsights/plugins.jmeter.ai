---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const tags = [...new Set(posts.map((post) => post.data.tags || []).flat())].sort();
---

<Layout title="All Tags - PerfAtlas Blog" description="Browse all topics covered in the PerfAtlas blog.">
    <Header />
    <main class="max-w-4xl mx-auto px-6 py-12 md:py-20 flex-grow w-full text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-12">
            Browse by <span class="text-green-600 dark:text-[#ccff00]">Topic</span>
        </h1>

        <div class="flex flex-wrap justify-center gap-4">
            {tags.map((tag) => (
                <a 
                    href={`/blog/tags/${tag}`} 
                    class="px-6 py-3 rounded-full bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-700 dark:text-gray-300 font-bold hover:border-primary/50 dark:hover:border-primary/50 hover:bg-green-50 dark:hover:bg-[#ccff00]/5 transition-all hover:-translate-y-1 shadow-sm hover:shadow-md"
                >
                    {tag}
                </a>
            ))}
        </div>
        
        <div class="mt-20">
            <a href="/blog" class="text-green-600 dark:text-[#ccff00] font-bold hover:underline">
                &larr; Back to all posts
            </a>
        </div>
    </main>
    <Footer />
</Layout>
