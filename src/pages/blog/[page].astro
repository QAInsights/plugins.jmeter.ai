---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { sortPosts, filterDrafts, getReadingTime } from '../../utils/blog';
import Search from 'astro-pagefind/components/Search';
import placeholderImg from '../../assets/blog/placeholder.png';

export async function getStaticPaths({ paginate }) {
    const allPosts = await getCollection('blog');
    const posts = sortPosts(filterDrafts(allPosts));
    // We only want paths for 2, 3, 4... since index.astro handles page 1
    return paginate(posts, { pageSize: 6 }).filter(p => p.params.page !== '1');
}

const { page } = Astro.props;
const posts = page.data;

// Get all unique tags for the sidebar
const allPosts = await getCollection('blog');
const allSortedPosts = sortPosts(filterDrafts(allPosts));
const uniqueTags = Array.from(new Set(allSortedPosts.flatMap(p => p.data.tags || []))).slice(0, 10);
---

<Layout title={`Blog - Page ${page.currentPage} - PerfAtlas`} description="Read the latest news and guides about JMeter plugins and performance testing.">
    <Header />
    
    <!-- Hero Header with Grid -->
    <section class="relative bg-dark-bg border-b border-white/5 pt-16 pb-24 overflow-hidden">
        <div class="absolute inset-0 grid-background opacity-20"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-dark-bg/80"></div>
        
        <div class="relative max-w-7xl mx-auto px-6 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-white mb-6">
                Blog <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-[#ccff00]">Archive</span>
            </h1>
            <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
                Page {page.currentPage} of {page.lastPage}. Browsing through our technical history.
            </p>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-6 py-16 flex-grow w-full">
        <div class="flex flex-col lg:flex-row gap-16">
            <!-- Sidebar -->
            <aside class="w-full lg:w-72 shrink-0">
                <div class="sticky top-24">
                    <div class="sidebar-item">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-6 border-b border-gray-200 dark:border-white/10 pb-2">Search</h3>
                        <Search 
                            id="search" 
                            className="pagefind-ui-custom" 
                            uiOptions={{ showImages: false }}
                        />
                    </div>

                    <div class="sidebar-item">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-6 border-b border-gray-200 dark:border-white/10 pb-2">Popular Tags</h3>
                        <div class="flex flex-wrap gap-2">
                            {uniqueTags.map(tag => (
                                <a href={`/blog/tags/${tag}`} class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:border-[#ccff00]/50 transition-all lowercase">
                                    #{tag}
                                </a>
                            ))}
                        </div>
                    </div>

                    <div class="sidebar-item">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-6 border-b border-gray-200 dark:border-white/10 pb-2">Subscribe</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">Stay up-to-date with the latest JMeter plugins and performance news.</p>
                        <a href="/rss.xml" class="flex items-center gap-2 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-black font-bold rounded-lg hover:bg-[#ccff00] dark:hover:bg-[#ccff00] hover:text-black transition-colors w-full justify-center shadow-lg shadow-black/5 dark:shadow-none">
                            RSS Feed
                        </a>
                    </div>
                </div>
            </aside>

            <!-- Main Feed -->
            <div class="flex-1">
                <div class="grid grid-cols-1 gap-12">
                    {posts.map((post) => (
                        <article class="group relative flex flex-col md:flex-row gap-8 items-start hover:bg-gray-50 dark:hover:bg-white/5 p-4 rounded-2xl transition-all duration-300 border border-transparent hover:border-gray-200 dark:hover:border-white/10">
                            <a href={`/blog/${post.id}`} class="w-full md:w-80 shrink-0 aspect-video rounded-xl overflow-hidden border border-gray-200 dark:border-white/10 relative shadow-sm group-hover:shadow-md transition-shadow">
                                <Image 
                                    src={post.data.image || placeholderImg} 
                                    alt={post.data.imageAlt || post.data.title}
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                    width={600}
                                    height={338}
                                    format="webp"
                                />
                            </a>
                            
                            <div class="flex-1 flex flex-col pt-2">
                                <time datetime={post.data.pubDate.toISOString()} class="text-[11px] font-mono text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-4 block">
                                    {post.data.pubDate.toLocaleDateString('en-US', {
                                        year: 'numeric',
                                        month: 'long',
                                        day: 'numeric',
                                    })}
                                    <span class="mx-2 text-gray-300 dark:text-gray-800">•</span>
                                    {getReadingTime(post.body || '')}
                                </time>
                                
                                <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 group-hover:text-green-600 dark:group-hover:text-[#ccff00] transition-colors leading-tight">
                                    <a href={`/blog/${post.id}`}>
                                        {post.data.title}
                                    </a>
                                </h2>
                                
                                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-6 line-clamp-3">
                                    {post.data.description}
                                </p>
                                
                                <div class="mt-auto flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-[#ccff00] flex items-center justify-center text-[10px] text-black font-black">
                                            {post.data.author.charAt(0)}
                                        </div>
                                        <span class="text-xs text-gray-600 dark:text-gray-300 font-medium">{post.data.author}</span>
                                    </div>
                                    <a href={`/blog/${post.id}`} class="text-[#ccff00] opacity-0 group-hover:opacity-100 transition-all flex items-center gap-1 text-xs font-bold uppercase tracking-widest">
                                        Read Post <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                    </a>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>

                <!-- Pagination Controls -->
                <nav class="mt-16 flex items-center justify-center gap-4">
                    {page.url.prev && (
                        <a href={page.url.prev === '/blog/1' ? '/blog' : page.url.prev} class="px-6 py-3 rounded-xl border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white font-bold hover:bg-gray-100 dark:hover:bg-white/5 transition-all text-sm shadow-sm hover:shadow-md">
                            ← Previous
                        </a>
                    )}
                    
                    <span class="text-gray-500 font-mono text-xs uppercase tracking-widest">
                        Page {page.currentPage} of {page.lastPage}
                    </span>

                    {page.url.next && (
                        <a href={page.url.next} class="px-6 py-3 rounded-xl border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white font-bold hover:bg-gray-100 dark:hover:bg-white/5 transition-all text-sm shadow-sm hover:shadow-md">
                            Next →
                        </a>
                    )}
                </nav>
            </div>
        </div>
    </main>
    <Footer />
</Layout>
