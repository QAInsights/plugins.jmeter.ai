---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import UsageChart from '../../components/UsageChart.astro';
import ChangelogTimeline from '../../components/ChangelogTimeline.astro';
import GitHubBadge from '../../components/GitHubBadge.astro';
import RelatedPluginsSection from '../../components/RelatedPluginsSection.astro';
import CommunityDiscussions from '../../components/CommunityDiscussions.astro';
import pluginsData from '../../data/plugins_data.json';
import { getRelatedPlugins, inferCategory, getChangelogTimeline, hasChangelog } from '../../utils/plugin';

// Make this a statically generated route
export async function getStaticPaths() {
    return pluginsData.map(plugin => ({
        params: { id: plugin.id },
        props: { plugin },
    }));
}

const { plugin } = Astro.props;

// Format data just like the Modal
const dlAbsolute = new Intl.NumberFormat('en-US').format(plugin.stats.absoluteDownloads);
const trendArrow = plugin.stats.trendingDelta > 0 ? '+' : '';
const trendDelta = new Intl.NumberFormat('en-US').format(plugin.stats.trendingDelta);

// Determine the active screenshot
let sUrl = plugin.screenshotUrl || '';
if (sUrl && !sUrl.startsWith('http')) {
    sUrl = 'https://jmeter-plugins.org' + (sUrl.startsWith('/') ? '' : '/') + sUrl;
}

// Generate the OG Image
const ogImage = sUrl || 'https://plugins.jmeter.ai/favicon.svg';

const title = `${plugin.name} | PerfAtlas`;
const description = `Discover ${plugin.name} by ${plugin.vendor}. ${plugin.description}`;
const url = `https://plugins.jmeter.ai/plugin/${plugin.id}`;

// Prepare Chart Data
const history = (plugin.stats.history || {}) as Record<string, number>;
const chartLabels = Object.keys(history).sort();
const chartData = chartLabels.map(l => history[l]);

// Related plugins (same vendor / same inferred category)
const { sameVendor, sameCategory } = getRelatedPlugins(plugin, pluginsData, { limit: 3 });
const relatedCategory = inferCategory(plugin);

// Release history / changelog timeline
const changelog = getChangelogTimeline(plugin);
const showChangelog = hasChangelog(plugin);
---

<Layout title={title} description={description} image={ogImage}>
    <Header />
    <main class="flex-grow flex flex-col py-16 px-6">
        <div class="max-w-4xl mx-auto w-full">
            
            {/* Back Button */}
            <a href="/" class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-900 dark:hover:text-white mb-8 transition-colors text-sm font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Back to Directory
            </a>

            {/* Plugin Header Card */}
            <div class={`relative bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 rounded-2xl shadow-xl overflow-hidden mb-8 ${plugin.isAiReady ? 'p-[2px] ai-glow-wrapper' : ''}`}>
                <div class={`relative bg-white dark:bg-dark-surface h-full w-full ${plugin.isAiReady ? 'rounded-[10px]' : ''}`}>
                    {(plugin.sponsored || plugin.isFeatured) && (
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary"></div>
                    )}
                    
                    <div class="p-8 md:p-12">
                        <div class="flex flex-col md:flex-row md:items-start justify-between gap-6 mb-8">
                            <div>
                                <h1 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white leading-tight tracking-tight mb-2">
                                    {plugin.name}
                                </h1>
                                <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest">
                                    By {plugin.vendor} &bull; ID: {plugin.id}
                                </p>
                            </div>
                            <div class="flex shrink-0 gap-3">
                                <button type="button" class="install-add-btn px-6 py-3 rounded-lg bg-gray-200 dark:bg-white/10 text-gray-700 dark:text-white font-bold hover:bg-gray-300 dark:hover:bg-white/20 transition-colors shadow-lg flex items-center gap-2" data-plugin-id={plugin.id}>
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                    <span>Install</span>
                                </button>
                                <a href={plugin.helpUrl} target="_blank" rel="noopener noreferrer" class="px-6 py-3 rounded-lg bg-gray-900 dark:bg-white text-white dark:text-dark-bg font-bold hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors shadow-lg flex items-center gap-2">
                                    View Repository
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                </a>
                            </div>
                        </div>

                        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 leading-relaxed mb-10">
                            {plugin.description}
                        </p>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
                            <div class="bg-gray-50 dark:bg-black/20 rounded-xl p-6 border border-gray-100 dark:border-white/5">
                                <h4 class="text-sm font-bold text-gray-500 uppercase mb-2">Total Downloads</h4>
                                <p class="text-3xl font-black text-gray-900 dark:text-white">{dlAbsolute}</p>
                            </div>
                            <div class="bg-gray-50 dark:bg-black/20 rounded-xl p-6 border border-gray-100 dark:border-white/5">
                                <h4 class="text-sm font-bold text-gray-500 uppercase mb-2">Downloads This Week</h4>
                                <p class={`text-3xl font-black ${plugin.stats.trendingDelta > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-500'}`}>
                                    {trendArrow}{trendDelta}
                                </p>
                            </div>
                        </div>

                        {sUrl && (
                            <div class="mb-10">
                                <img src={sUrl} alt={`${plugin.name} UI Screenshot`} class="w-full h-auto rounded-xl border border-gray-200 dark:border-white/5 bg-gray-50 dark:bg-black/20 shadow-sm" loading="lazy" />
                            </div>
                        )}

                        <UsageChart labels={chartLabels} data={chartData} />

                        {plugin.componentClasses && plugin.componentClasses.length > 0 && (
                            <div class="mb-10">
                                <h4 class="text-sm font-bold text-gray-900 dark:text-white mb-4 uppercase tracking-wide">Component Classes</h4>
                                <div class="bg-gray-50 dark:bg-black/20 rounded-xl p-6 font-mono text-xs md:text-sm overflow-x-auto border border-gray-100 dark:border-white/5 max-h-64 overflow-y-auto leading-loose whitespace-pre text-gray-700 dark:text-gray-300">
                                    {plugin.componentClasses.join('\n')}
                                </div>
                            </div>
                        )}
                        
                        {showChangelog && <ChangelogTimeline entries={changelog} />}

                        <GitHubBadge url={url} />

                        <RelatedPluginsSection
                            sameVendor={sameVendor}
                            sameCategory={sameCategory}
                            vendor={plugin.vendor}
                            category={relatedCategory}
                        />

                        <CommunityDiscussions />

                    </div>
                </div>
            </div>

        </div>
    </main>
    <Footer />
</Layout>
