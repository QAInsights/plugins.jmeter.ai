---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import pluginsData from '../../data/plugins_data.json';
import { getVendors } from '../../utils/plugin';

const vendors = getVendors(pluginsData as any[]);

const formatNumber = (n: number) => new Intl.NumberFormat('en-US').format(n);

const totalPlugins = vendors.reduce((sum, v) => sum + v.pluginCount, 0);
const totalDownloads = vendors.reduce((sum, v) => sum + v.totalDownloads, 0);
const totalAiReady = vendors.reduce((sum, v) => sum + v.aiReadyCount, 0);

const [first, second, third, ...rest] = vendors;
const podium = [first, second, third].filter(Boolean);

const title = 'Vendors & Leaderboard | PerfAtlas';
const description = `Browse ${vendors.length} JMeter plugin vendors on PerfAtlas, ranked by total downloads. Discover the teams behind ${formatNumber(totalPlugins)} plugins with ${formatNumber(totalDownloads)} cumulative downloads.`;
---

<Layout title={title} description={description}>
    <Header />
    <main class="flex-grow flex flex-col py-12 md:py-16 px-6">
        <div class="max-w-7xl mx-auto w-full">

            {/* Back Link */}
            <a href="/" class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-900 dark:hover:text-white mb-8 transition-colors text-sm font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Back to Directory
            </a>

            {/* Page Hero */}
            <div class="mb-12">
                <p class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-3">Leaderboard</p>
                <h1 class="text-4xl md:text-6xl font-black text-gray-900 dark:text-white leading-tight tracking-tighter mb-4">
                    JMeter Plugin <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-[#ccff00]">Vendors</span>
                </h1>
                <p class="text-lg text-gray-600 dark:text-gray-300 max-w-3xl leading-relaxed">
                    {vendors.length} teams and maintainers shipping JMeter plugins; ranked by total downloads, complete with per-vendor catalogs.
                </p>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mt-10">
                    <div class="bg-white dark:bg-dark-surface rounded-xl p-5 border border-gray-200 dark:border-white/10">
                        <h4 class="text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Vendors</h4>
                        <p class="text-2xl md:text-3xl font-black text-gray-900 dark:text-white">{formatNumber(vendors.length)}</p>
                    </div>
                    <div class="bg-white dark:bg-dark-surface rounded-xl p-5 border border-gray-200 dark:border-white/10">
                        <h4 class="text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Plugins</h4>
                        <p class="text-2xl md:text-3xl font-black text-gray-900 dark:text-white">{formatNumber(totalPlugins)}</p>
                    </div>
                    <div class="bg-white dark:bg-dark-surface rounded-xl p-5 border border-gray-200 dark:border-white/10">
                        <h4 class="text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">Cumulative Downloads</h4>
                        <p class="text-2xl md:text-3xl font-black text-gray-900 dark:text-white">{formatNumber(totalDownloads)}</p>
                    </div>
                    <div class="bg-white dark:bg-dark-surface rounded-xl p-5 border border-gray-200 dark:border-white/10">
                        <h4 class="text-xs font-bold text-gray-500 uppercase mb-2 tracking-wide">AI Ready</h4>
                        <p class="text-2xl md:text-3xl font-black text-gray-900 dark:text-white">{formatNumber(totalAiReady)}</p>
                    </div>
                </div>
            </div>

            {/* Podium */}
            {podium.length === 3 && (
                <div class="mb-16">
                    <h2 class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-6">Top Vendors</h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        {podium.map((v, i) => (
                            <a
                                href={`/vendor/${v.slug}`}
                                class={`group relative flex flex-col rounded-2xl overflow-hidden border transition-all duration-300 hover:-translate-y-1 hover:shadow-xl
                                    ${i === 0
                                        ? 'bg-white dark:bg-dark-surface border-primary/50 dark:border-[#ccff00]/30 shadow-lg shadow-primary/10 dark:shadow-[0_0_25px_rgba(204,255,0,0.1)]'
                                        : 'bg-white dark:bg-dark-surface border-gray-200 dark:border-white/10 hover:border-primary/40'
                                    }`}
                            >
                                <div class={`absolute top-0 left-0 w-full h-1 ${
                                    i === 0 ? 'bg-gradient-to-r from-primary to-secondary'
                                    : i === 1 ? 'bg-gradient-to-r from-gray-300 to-gray-400 dark:from-gray-500 dark:to-gray-600'
                                    : 'bg-gradient-to-r from-amber-400 to-amber-600'
                                }`}></div>
                                <div class="p-6 flex flex-col gap-4">
                                    <div class="flex items-center justify-between">
                                        <span class={`text-2xl font-black ${
                                            i === 0 ? 'text-primary dark:text-[#ccff00]'
                                            : i === 1 ? 'text-gray-400'
                                            : 'text-amber-500'
                                        }`}>#{i + 1}</span>
                                        <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500">Top {i + 1}</span>
                                    </div>
                                    <h3 class="text-2xl font-black text-gray-900 dark:text-white leading-tight group-hover:text-primary dark:group-hover:text-[#ccff00] transition-colors">
                                        {v.vendor}
                                    </h3>
                                    <div class="grid grid-cols-2 gap-3 text-sm">
                                        <div>
                                            <p class="text-[10px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500">Plugins</p>
                                            <p class="font-bold text-gray-900 dark:text-white">{formatNumber(v.pluginCount)}</p>
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500">Downloads</p>
                                            <p class="font-bold text-gray-900 dark:text-white">{formatNumber(v.totalDownloads)}</p>
                                        </div>
                                    </div>
                                    {v.topPlugin && (
                                        <div class="pt-3 border-t border-gray-100 dark:border-white/5">
                                            <p class="text-[10px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-1">Flagship</p>
                                            <p class="text-sm font-semibold text-gray-700 dark:text-gray-300 line-clamp-1">{v.topPlugin.name}</p>
                                        </div>
                                    )}
                                </div>
                            </a>
                        ))}
                    </div>
                </div>
            )}

            {/* Controls */}
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                <div class="relative w-full md:max-w-sm">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </span>
                    <input
                        type="text"
                        id="vendorSearch"
                        placeholder="Search vendors..."
                        class="w-full bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 rounded-lg pl-12 pr-4 py-3 text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-white/30 outline-none focus:border-primary/50 transition-colors"
                    />
                </div>

                <div class="flex items-center gap-3">
                    <select id="vendorIndexSort" class="bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 text-gray-700 dark:text-gray-300 text-sm font-semibold rounded-lg px-3 py-2 focus:outline-none focus:border-primary/50 cursor-pointer shadow-sm appearance-none">
                        <option value="downloads-desc">Sort by: Downloads</option>
                        <option value="trending-desc">Trending</option>
                        <option value="plugins-desc">Plugin Count</option>
                        <option value="ai-desc">AI Ready</option>
                        <option value="name-asc">Name: A to Z</option>
                    </select>
                    <span id="vendorIndexCount" class="text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-white/10 px-3 py-2 rounded-lg text-sm font-bold truncate shrink-0">{vendors.length} vendors</span>
                </div>
            </div>

            <div id="vendorIndexNoResults" class="hidden text-center py-20 border border-gray-200 dark:border-white/5 rounded-2xl bg-gray-50 dark:bg-white/[0.01]">
                <h3 class="text-xl text-gray-500 dark:text-gray-400">No vendors match your search.</h3>
            </div>

            {/* Full list (includes the podium so sort/search stays consistent) */}
            <div id="vendorIndexGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {vendors.map((v, index) => (
                    <a
                        href={`/vendor/${v.slug}`}
                        class="vendor-card group relative flex flex-col rounded-xl border border-gray-200 dark:border-white/10 bg-white dark:bg-dark-surface p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-lg"
                        data-name={v.vendor.toLowerCase()}
                        data-downloads={v.totalDownloads}
                        data-trending={v.totalTrending}
                        data-plugins={v.pluginCount}
                        data-ai={v.aiReadyCount}
                        data-index={index}
                    >
                        <div class="flex items-start justify-between gap-3 mb-3">
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white leading-snug group-hover:text-primary dark:group-hover:text-[#ccff00] transition-colors line-clamp-2">
                                {v.vendor}
                            </h3>
                            <span class="shrink-0 px-2 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-300">#{index + 1}</span>
                        </div>

                        <div class="grid grid-cols-3 gap-2 mb-3">
                            <div>
                                <p class="text-[9px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500">Plugins</p>
                                <p class="text-sm font-bold text-gray-900 dark:text-white">{formatNumber(v.pluginCount)}</p>
                            </div>
                            <div>
                                <p class="text-[9px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500">Downloads</p>
                                <p class="text-sm font-bold text-gray-900 dark:text-white">{formatNumber(v.totalDownloads)}</p>
                            </div>
                            <div>
                                <p class="text-[9px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500">This Week</p>
                                <p class={`text-sm font-bold ${v.totalTrending > 0 ? 'text-green-600 dark:text-green-400' : v.totalTrending < 0 ? 'text-red-500' : 'text-gray-500 dark:text-gray-400'}`}>
                                    {v.totalTrending > 0 ? '+' : ''}{formatNumber(v.totalTrending)}
                                </p>
                            </div>
                        </div>

                        {v.aiReadyCount > 0 && (
                            <span class="inline-flex items-center gap-1 self-start px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide bg-primary/20 text-primary-dark dark:text-[#ccff00] border border-primary/40 mb-3">
                                {v.aiReadyCount} AI Ready
                            </span>
                        )}

                        {v.topPlugin && (
                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-auto pt-2 border-t border-gray-100 dark:border-white/5 line-clamp-1">
                                <span class="font-bold text-gray-700 dark:text-gray-300">Top:</span> {v.topPlugin.name}
                            </p>
                        )}
                    </a>
                ))}
            </div>

        </div>
    </main>
    <Footer />
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const grid = document.getElementById('vendorIndexGrid');
        const searchInput = document.getElementById('vendorSearch') as HTMLInputElement | null;
        const sortSelect = document.getElementById('vendorIndexSort') as HTMLSelectElement | null;
        const count = document.getElementById('vendorIndexCount');
        const noResults = document.getElementById('vendorIndexNoResults');

        if (!grid) return;

        const cards = Array.from(grid.querySelectorAll<HTMLElement>('.vendor-card'));
        const cache = cards.map((el) => ({
            el,
            name: el.getAttribute('data-name') || '',
            downloads: parseInt(el.getAttribute('data-downloads') || '0', 10),
            trending: parseInt(el.getAttribute('data-trending') || '0', 10),
            plugins: parseInt(el.getAttribute('data-plugins') || '0', 10),
            ai: parseInt(el.getAttribute('data-ai') || '0', 10),
            index: parseInt(el.getAttribute('data-index') || '0', 10),
        }));

        let search = '';

        function applySort() {
            if (!sortSelect) return;
            const value = sortSelect.value;
            const sorted = cache.slice().sort((a, b) => {
                if (value === 'name-asc') return a.name.localeCompare(b.name);
                if (value === 'trending-desc') return b.trending - a.trending;
                if (value === 'plugins-desc') return b.plugins - a.plugins;
                if (value === 'ai-desc') {
                    const diff = b.ai - a.ai;
                    return diff !== 0 ? diff : b.downloads - a.downloads;
                }
                return b.downloads - a.downloads;
            });
            requestAnimationFrame(() => {
                sorted.forEach((item, i) => { item.el.style.order = String(i); });
            });
        }

        function applyFilter() {
            let matched = 0;
            cache.forEach((item) => {
                const isMatch = search === '' || item.name.includes(search);
                if (isMatch) {
                    matched++;
                    item.el.classList.remove('hidden');
                } else {
                    item.el.classList.add('hidden');
                }
            });
            if (count) {
                count.textContent = `${matched} vendor${matched !== 1 ? 's' : ''}`;
            }
            if (noResults) {
                noResults.classList.toggle('hidden', matched !== 0);
            }
        }

        if (searchInput) {
            let debounceTimer: number | null = null;
            searchInput.addEventListener('input', (e) => {
                if (debounceTimer) clearTimeout(debounceTimer);
                debounceTimer = window.setTimeout(() => {
                    search = (e.target as HTMLInputElement).value.toLowerCase().trim();
                    applyFilter();
                }, 200);
            });
        }

        if (sortSelect) {
            sortSelect.addEventListener('change', applySort);
        }

        applySort();
        applyFilter();
    });
</script>
