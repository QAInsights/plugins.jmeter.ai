---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
    title="Settings | PerfAtlas"
    description="Manage your PerfAtlas account settings and preferences."
>
    <Header />
    
    <main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 py-12 w-full">
        {/* Loading State */}
        <div id="settings-loading" class="max-w-3xl mx-auto">
            <div class="animate-pulse space-y-4">
                <div class="h-8 bg-gray-200 dark:bg-white/10 rounded w-1/3"></div>
                <div class="h-4 bg-gray-200 dark:bg-white/10 rounded w-1/2"></div>
                <div class="h-64 bg-gray-200 dark:bg-white/10 rounded-xl mt-8"></div>
            </div>
        </div>

        {/* Authenticated Content */}
        <div id="settings-content" class="max-w-3xl mx-auto hidden">
            <!-- Page Header -->
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
                    Settings
                </h1>
                <p class="text-gray-600 dark:text-gray-400">
                    Manage your account and preferences
                </p>
            </div>

            <!-- Placeholder Content -->
            <div class="bg-white dark:bg-dark-surface rounded-xl border border-gray-200 dark:border-white/10 p-8 shadow-sm">
                <div class="flex items-center justify-center py-16">
                    <div class="text-center">
                        <svg 
                            class="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-gray-600" 
                            fill="none" 
                            stroke="currentColor" 
                            viewBox="0 0 24 24"
                        >
                            <path 
                                stroke-linecap="round" 
                                stroke-linejoin="round" 
                                stroke-width="1.5" 
                                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                            />
                            <path 
                                stroke-linecap="round" 
                                stroke-linejoin="round" 
                                stroke-width="1.5" 
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                            />
                        </svg>
                        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">
                            Settings Page Coming Soon
                        </h2>
                        <p class="text-gray-500 dark:text-gray-400 max-w-md mx-auto">
                            This page is under construction. Soon you'll be able to manage your profile, 
                            notification preferences, and account settings here.
                        </p>
                    </div>
                </div>

                <!-- Quick Links Section -->
                <div class="border-t border-gray-100 dark:border-white/5 pt-8 mt-8">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
                        Quick Links
                    </h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <a 
                            href="/" 
                            class="flex items-center gap-3 p-4 rounded-lg bg-gray-50 dark:bg-white/5 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors"
                        >
                            <div class="w-10 h-10 rounded-lg bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-600 dark:text-[#ccff00]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                                </svg>
                            </div>
                            <div>
                                <p class="font-medium text-gray-900 dark:text-white">Home</p>
                                <p class="text-sm text-gray-500 dark:text-gray-400">Browse plugins</p>
                            </div>
                        </a>
                        <a 
                            href="/collections" 
                            class="flex items-center gap-3 p-4 rounded-lg bg-gray-50 dark:bg-white/5 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors"
                        >
                            <div class="w-10 h-10 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
                                <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                                </svg>
                            </div>
                            <div>
                                <p class="font-medium text-gray-900 dark:text-white">Collections</p>
                                <p class="text-sm text-gray-500 dark:text-gray-400">Curated plugin stacks</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {/* Unauthenticated State */}
        <div id="settings-unauthorized" class="max-w-3xl mx-auto hidden">
            <div class="bg-white dark:bg-dark-surface rounded-xl border border-gray-200 dark:border-white/10 p-8 shadow-sm text-center">
                <svg 
                    class="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-gray-600" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-2">
                    Sign In Required
                </h2>
                <p class="text-gray-500 dark:text-gray-400 mb-6">
                    Please sign in to access your settings.
                </p>
                <button 
                    id="settings-sign-in-btn"
                    class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-green-600 hover:bg-green-700 dark:bg-[#ccff00] dark:hover:bg-[#b8e600] text-white dark:text-black font-semibold transition-all hover:scale-105"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                    </svg>
                    Sign In
                </button>
            </div>
        </div>
    </main>
    
    <Footer />

    <script>
        import { $userStore, $clerkStore } from '@clerk/astro/client';

        const loadingEl = document.getElementById('settings-loading');
        const contentEl = document.getElementById('settings-content');
        const unauthorizedEl = document.getElementById('settings-unauthorized');
        const signInBtn = document.getElementById('settings-sign-in-btn');

        function updateState() {
            const user = $userStore.get();
            const clerk = $clerkStore.get();
            const isLoading = !clerk;

            if (isLoading) {
                // Still loading - show skeleton
                loadingEl?.classList.remove('hidden');
                contentEl?.classList.add('hidden');
                unauthorizedEl?.classList.add('hidden');
            } else if (user) {
                // Authenticated - show content
                loadingEl?.classList.add('hidden');
                contentEl?.classList.remove('hidden');
                unauthorizedEl?.classList.add('hidden');
            } else {
                // Not authenticated - show sign in prompt
                loadingEl?.classList.add('hidden');
                contentEl?.classList.add('hidden');
                unauthorizedEl?.classList.remove('hidden');
            }
        }

        // Subscribe to auth changes
        $userStore.subscribe(() => updateState());
        $clerkStore.subscribe(() => updateState());

        // Sign in button handler
        signInBtn?.addEventListener('click', () => {
            const clerk = $clerkStore.get();
            if (clerk) {
                clerk.openSignIn({
                    appearance: {
                        elements: {
                            formButtonPrimary: 'bg-green-600 hover:bg-green-700',
                        }
                    }
                });
            }
        });

        // Initial check
        updateState();
    </script>
</Layout>
