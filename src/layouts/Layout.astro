---
import '../styles/global.css';
import ScrollToTop from '../components/ScrollToTop.astro';
import CompareFloatingBar from '../components/CompareFloatingBar.astro';
import InstallFloatingBar from '../components/InstallFloatingBar.astro';
import FavoritesManager from '../components/FavoritesManager.astro';
import { SEO } from "astro-seo";
import Analytics from '@vercel/analytics/astro';

interface Props {
	title: string;
    description?: string;
    image?: string;
    type?: "website" | "article";
    articleDate?: string;
    articleAuthor?: string;
    schema?: Record<string, unknown>;
}

const { 
    title, 
    description = "Discover, search, and track modern and AI-ready JMeter plugins. Community-driven directory automatically synced daily.", 
    image = "/favicon.svg",
    type = "website",
    articleDate,
    articleAuthor,
    schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://plugins.jmeter.ai');
const socialImageURL = new URL(image, Astro.site || 'https://plugins.jmeter.ai');

// Best-effort MIME hint so crawlers can pick the image without HEAD-probing.
const socialImageType = /\.png($|\?)/i.test(socialImageURL.pathname)
    ? 'image/png'
    : /\.jpe?g($|\?)/i.test(socialImageURL.pathname)
        ? 'image/jpeg'
        : /\.webp($|\?)/i.test(socialImageURL.pathname)
            ? 'image/webp'
            : /\.svg($|\?)/i.test(socialImageURL.pathname)
                ? 'image/svg+xml'
                : undefined;
const isGeneratedOg = socialImageURL.pathname.startsWith('/og/') && socialImageURL.pathname.endsWith('.png');
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/site.webmanifest" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		
        <SEO
            title={title}
            description={description}
            canonical={canonicalURL.toString()}
            openGraph={{
                basic: {
                    title: title,
                    type: type,
                    image: socialImageURL.toString(),
                    url: canonicalURL.toString(),
                },
                article: type === 'article' ? {
                    publishedTime: articleDate,
                    authors: [articleAuthor || 'NaveenKumar Namachivayam'],
                } : undefined
            }}
            twitter={{
                creator: "@qainsights",
                card: "summary_large_image",
                title: title,
                description: description,
                image: socialImageURL.toString(),
            }}
            extend={{
                meta: [
                    { name: "twitter:url", content: canonicalURL.toString() },
                    ...(isGeneratedOg ? [
                        { property: "og:image:width", content: "1200" },
                        { property: "og:image:height", content: "630" },
                        { property: "og:image:alt", content: title },
                    ] : []),
                    ...(socialImageType ? [
                        { property: "og:image:type", content: socialImageType },
                    ] : []),
                ],
            }}
        />

        <script>
            if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        </script>
        
        
        <script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>

        {schema && (
            <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        )}

        {/* Cloudflare Web Analytics */}
        <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "18dd9054c9194403bcc8517c16fa73ad"}'></script>
        
        {/* Vercel Web Analytics */}
        <Analytics />
	</head>
	<body class="min-h-screen flex flex-col font-sans antialiased overflow-x-hidden selection:bg-primary dark:selection:bg-[#ccff00] selection:text-white dark:selection:text-dark-bg">
        <slot />
        <ScrollToTop />
        <CompareFloatingBar />
        <InstallFloatingBar />
        <FavoritesManager />
    </body>
</html>
