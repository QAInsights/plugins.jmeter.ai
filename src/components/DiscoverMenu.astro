---
---
<!-- Discover mega menu -->
<div class="relative group" id="discoverMenuWrapper">
    <button type="button" aria-haspopup="true" class="flex items-center gap-1 font-bold text-gray-900 dark:text-white hover:text-green-600 dark:hover:text-[#ccff00] transition-colors">
        Discover
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
    </button>
    <!-- Mega panel -->
    <div class="absolute top-full left-1/2 -translate-x-1/2 w-[540px] pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 ease-out pointer-events-none group-hover:pointer-events-auto" style="z-index:999">
        <div class="absolute top-1.5 left-1/2 -translate-x-1/2 w-3 h-3 rotate-45 bg-white dark:bg-[#1a1a1a] border-l border-t border-gray-200 dark:border-white/10 rounded-sm"></div>
        <div class="overflow-hidden rounded-2xl shadow-2xl border border-gray-200 dark:border-white/10 bg-white dark:bg-[#1a1a1a]">
            <div class="h-1 bg-gradient-to-r from-green-500 via-green-400 to-[#ccff00]"></div>
            <div class="px-6 pt-4 pb-2">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500">PerfAtlas Features</p>
            </div>
            <div class="px-4 pb-5 grid grid-cols-2 gap-1.5">
                <a href="/#search" class="group/card flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                    <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-[#ccff00]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white group-hover/card:text-green-600 dark:group-hover/card:text-[#ccff00] transition-colors">Search</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 leading-snug">Find plugins instantly by name, vendor, or category</p>
                    </div>
                </a>
                <a href="/#compare" class="group/card flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                    <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white group-hover/card:text-blue-600 dark:group-hover/card:text-blue-400 transition-colors">Compare</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 leading-snug">Side-by-side plugin comparison at a glance</p>
                    </div>
                </a>
                <a href="/#statistics" class="group/card flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                    <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg bg-purple-50 dark:bg-purple-900/20 text-purple-600 dark:text-purple-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white group-hover/card:text-purple-600 dark:group-hover/card:text-purple-400 transition-colors">Statistics</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 leading-snug">Download trends and usage insights</p>
                    </div>
                </a>
                <a href="/#ai-ready" class="group/card flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                    <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg bg-yellow-50 dark:bg-yellow-900/20 text-yellow-600 dark:text-yellow-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white group-hover/card:text-yellow-600 dark:group-hover/card:text-yellow-400 transition-colors">AI Ready Plugins</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 leading-snug">Curated plugins optimized for AI workflows</p>
                    </div>
                </a>
                <a href="/#install" class="group/card col-span-2 flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                    <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white group-hover/card:text-orange-600 dark:group-hover/card:text-orange-400 transition-colors">One-click Install</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 leading-snug">Add plugins to your install list in a single click — no manual steps required</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>
