---
const lastSyncDate = new Date().toUTCString().replace('GMT', 'UTC');
---
<footer class="border-t border-gray-200 dark:border-white/10 py-16 px-6 bg-gray-50/50 dark:bg-dark-bg/50 backdrop-blur-sm mt-auto">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
            <div class="space-y-4">
                <div class="flex items-center gap-2">
                    <span class="text-xl font-extrabold tracking-tight text-gray-900 dark:text-white">Perf<span class="text-green-600 dark:text-[#ccff00]">Atlas</span></span>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed max-w-xs">
                    The modern directory for JMeter plugins. Tracking daily performance trends and community growth.
                </p>
                <div class="flex items-center gap-4">
                    <a href="https://x.com/qainsights" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors" aria-label="X (Twitter)">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
                    </a>
                    <a href="https://youtube.com/@qainsights" target="_blank" rel="noopener" class="text-gray-400 hover:text-[#FF0000] transition-colors" aria-label="YouTube">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505a3.017 3.017 0 00-2.122 2.136C0 8.055 0 12 0 12s0 3.945.501 5.814a3.015 3.015 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.945 24 12 24 12s0-3.945-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                    <a href="https://linkedin.com/in/naveenkumarn" target="_blank" rel="noopener" class="text-gray-400 hover:text-[#0A66C2] transition-colors" aria-label="LinkedIn">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zM7.119 20.452H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
