                    <a href="https://github.com/qainsights" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors" aria-label="GitHub">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    </a>
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-8 md:col-span-2">
                <div class="space-y-4">
                    <h4 class="text-sm font-bold uppercase tracking-widest text-gray-900 dark:text-white">Platform</h4>
                    <ul class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
                        <li><a href="/blog" class="hover:text-green-600 dark:hover:text-[#ccff00] transition-colors">Blog</a></li>
                        <li><a href="https://jmeter.ai" class="hover:text-green-600 dark:hover:text-[#ccff00] transition-colors">JMeter.ai</a></li>
                        <li><a href="https://ai.dosa.dev" class="hover:text-green-600 dark:hover:text-[#ccff00] transition-colors">AI Collections</a></li>
                    </ul>
                </div>
                <div class="space-y-4">
                    <h4 class="text-sm font-bold uppercase tracking-widest text-gray-900 dark:text-white">Network</h4>
                    <ul class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
                        <li><a href="https://qainsights.com" class="hover:text-green-600 dark:hover:text-[#ccff00] transition-colors">QAInsights</a></li>
                        <li><a href="https://dosa.dev" class="hover:text-green-600 dark:hover:text-[#ccff00] transition-colors">Portfolio</a></li>
                        <li><a href="https://www.buymeacoffee.com/qainsights" class="hover:text-green-600 dark:hover:text-[#ccff00] transition-colors">Support Development</a></li>
                    </ul>
                </div>
            </div>
        </div>
        
        <div class="pt-8 border-t border-gray-200 dark:border-white/5 flex flex-col md:flex-row items-center justify-between gap-6 text-xs text-gray-500 dark:text-gray-400 font-medium">
            <p>&copy; {new Date().getFullYear()} PerfAtlas. Built by <a href="https://dosa.dev" class="text-gray-900 dark:text-white hover:underline">NaveenKumar Namachivayam</a>.</p>
            <div class="flex items-center gap-4">
                <span>Last directory sync: <span class="font-mono bg-gray-200 dark:bg-white/5 px-1.5 py-0.5 rounded ml-1">{lastSyncDate}</span></span>
            </div>
        </div>
    </div>
</footer>
