---
const { plugin } = Astro.props;

// Determine tags
const tags = [];
if (plugin.isFeatured) tags.push('Featured');
if (plugin.isAiReady) tags.push('AI Ready');
if (plugin.sponsored) tags.push('Sponsored');

// Try to infer a category from class names
let category = 'Others';
if (plugin.componentClasses) {
  const classesStr = plugin.componentClasses.join(' ').toLowerCase();
  // Using exact broader categories requested
  if (classesStr.includes('assertion')) category = 'Assertions';
  else if (classesStr.includes('listener') || classesStr.includes('visualizer')) category = 'Listeners';
  else if (classesStr.includes('sampler')) category = 'Samplers';
  else if (classesStr.includes('config')) category = 'Configs';
  else if (classesStr.includes('timer')) category = 'Timers';
  else if (classesStr.includes('processor')) category = 'Processors';
}

const formatNumber = (num: number) => new Intl.NumberFormat('en-US').format(num);
---

<div tabindex="0" role="button"
   class={`plugin-card text-left group relative flex flex-col rounded-xl overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-1 w-full cursor-pointer ${
     plugin.isAiReady
       ? 'ai-glow-wrapper shadow-md dark:shadow-[0_0_15px_rgba(155,114,203,0.1)] hover:shadow-xl dark:hover:shadow-[0_0_25px_rgba(66,133,244,0.3)]'
       : 'bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 hover:border-primary/50 dark:hover:border-primary/50 dark:hover:shadow-[0_0_20px_rgba(204,255,0,0.15)]'
   }`}
   data-category={category.toLowerCase()}
   data-plugin={JSON.stringify(plugin)}
>
  
  <div class={`flex flex-col h-full w-full relative z-10 ${plugin.isAiReady ? 'bg-white dark:bg-dark-surface rounded-[10px]' : ''}`}>
    {/* Sponsored / Featured Highlight */}
    {(plugin.sponsored || plugin.isFeatured) && (
      <div class={`absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary z-20 ${plugin.isAiReady ? 'rounded-t-[10px]' : ''}`}></div>
    )}

    <div class="p-6 flex flex-col h-full">
    
    <div class="flex items-center justify-between mb-2 relative z-10">
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-mono text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-white/5 py-0.5 px-1.5 rounded">{plugin.id}</span>
        <button type="button" class="copy-id-btn p-1 -ml-1 text-gray-400 hover:text-primary dark:hover:text-[#ccff00] transition-colors" data-plugin-id={plugin.id} title="Copy ID">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
        </button>
      </div>
      
      <div class="flex items-center gap-1">
        <button
          type="button"
          class="install-add-btn group/install relative flex items-center justify-center w-7 h-7 rounded-md text-gray-400 dark:text-gray-500 hover:text-green-600 dark:hover:text-green-400 hover:bg-green-500/10 border border-transparent hover:border-green-500/30 transition-all z-20"
          data-plugin-id={plugin.id}
          aria-label="Add to install list"
          title="Add to install list"
          onclick="event.stopPropagation()"
        >
          <svg class="w-4 h-4 install-icon-plus" fill="none" stroke="currentColor" stroke-width="2.25" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
          <svg class="w-4 h-4 install-icon-check hidden" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
          <span class="sr-only install-btn-label">Install</span>
        </button>
        <label class="flex items-center gap-1.5 cursor-pointer group/compare px-1.5 py-1 rounded-md hover:bg-gray-100 dark:hover:bg-white/5 transition-colors" onclick="event.stopPropagation()" title="Add to compare">
          <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500 group-hover/compare:text-gray-700 dark:group-hover/compare:text-gray-200 transition-colors">Compare</span>
          <div class="relative inline-flex items-center">
            <input type="checkbox" class="compare-checkbox sr-only peer" data-plugin-id={plugin.id}>
            <div class="w-8 h-4 bg-gray-200 dark:bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-primary dark:peer-checked:bg-[#ccff00]"></div>
          </div>
        </label>
      </div>
    </div>

    <div class="flex justify-between items-start mb-4">
      <div class="flex flex-col">
        <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-primary dark:group-hover:text-[#ccff00] transition-colors leading-tight line-clamp-2">
          {plugin.name}
        </h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 uppercase tracking-wider font-semibold">By {plugin.vendor}</p>
      </div>

      {tags.length > 0 && (
        <div class="flex flex-col gap-2 items-end shrink-0 pl-3">
          {tags.map(tag => (
            <span class={`px-2 py-1 text-[9px] uppercase font-bold rounded-sm whitespace-nowrap
              ${tag === 'AI Ready' ? 'bg-primary/20 text-primary-dark dark:text-[#ccff00] border border-primary/50' : ''}
              ${tag === 'Sponsored' ? 'bg-secondary/10 text-secondary border border-secondary/30' : ''}
              ${tag === 'Featured' ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 border border-purple-300 dark:border-purple-500/50' : ''}
            `}>
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-6 flex-grow line-clamp-3">
      {plugin.description}
    </p>

    <div class="mt-auto pt-4 border-t border-gray-100 dark:border-white/5 flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
      <div class="flex items-center gap-2">
        <span class="flex items-center gap-1" title="Total Downloads">
          <svg class="w-4 h-4 text-primary dark:text-[#ccff00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          <span class="font-medium text-gray-700 dark:text-gray-300">{formatNumber(plugin.stats.absoluteDownloads)}</span>
        </span>
      </div>
      
      <div class="flex items-center gap-3">
        {plugin.stats.trendingDelta > 0 && (
          <span class="flex items-center gap-1 text-green-600 dark:text-green-400" title="Downloads this week">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            +{formatNumber(plugin.stats.trendingDelta)}
          </span>
        )}
        {plugin.stats.trendingDelta < 0 && (
          <span class="flex items-center gap-1 text-red-500" title="Downloads this week">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0v-8m0 8l-8-8-4 4-6-6"></path></svg>
            {formatNumber(plugin.stats.trendingDelta)}
          </span>
        )}
        <span class="bg-gray-100 dark:bg-white/5 px-2 py-1 rounded text-gray-600 dark:text-gray-400">
          {category}
        </span>
      </div>
    </div>
  </div>
</div>
