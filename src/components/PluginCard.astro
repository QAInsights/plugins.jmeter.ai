---
const { plugin } = Astro.props;

// Determine tags
const tags = [];
if (plugin.isAiReady) tags.push('AI Ready');
if (plugin.sponsored) tags.push('Sponsored');

// Try to infer a category from class names
let category = 'Plugin';
if (plugin.componentClasses) {
  const classesStr = plugin.componentClasses.join(' ').toLowerCase();
  if (classesStr.includes('assertion')) category = 'Assertion';
  else if (classesStr.includes('listener')) category = 'Listener';
  else if (classesStr.includes('sampler')) category = 'Sampler';
  else if (classesStr.includes('config')) category = 'Config';
  else if (classesStr.includes('timer')) category = 'Timer';
}

const formatNumber = (num) => new Intl.NumberFormat('en-US').format(num);
---

<a href={plugin.helpUrl} target="_blank" rel="noopener noreferrer" class="group relative flex flex-col bg-bg-surface border border-white/5 hover:border-primary/50 rounded-xl overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(204,255,0,0.15)] hover:-translate-y-1">
  
  {/* Sponsored Highlight */}
  {plugin.sponsored && (
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary"></div>
  )}

  <div class="p-6 flex flex-col h-full">
    <div class="flex justify-between items-start mb-4">
      <div class="flex flex-col">
        <h3 class="text-xl font-bold text-text-main group-hover:text-primary transition-colors leading-tight">
          {plugin.name}
        </h3>
        <p class="text-xs text-text-muted mt-1 uppercase tracking-wider font-semibold">By {plugin.vendor}</p>
      </div>

      {tags.length > 0 && (
        <div class="flex flex-col gap-2 items-end shrink-0 pl-4">
          {tags.map(tag => (
            <span class={`px-2 py-1 text-[10px] uppercase font-bold rounded-sm ${tag === 'AI Ready' ? 'bg-primary/10 text-primary border border-primary/30 shadow-[0_0_10px_rgba(204,255,0,0.2)]' : 'bg-secondary/10 text-secondary border border-secondary/30'}`}>
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <p class="text-sm text-text-muted leading-relaxed mb-6 flex-grow line-clamp-3">
      {plugin.description}
    </p>

    <div class="mt-auto pt-4 border-t border-white/5 flex items-center justify-between text-xs text-text-muted">
      <div class="flex items-center gap-2">
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          <span class="font-medium text-text-main">{formatNumber(plugin.stats.absoluteDownloads)}</span>
        </span>
      </div>
      
      <div class="flex items-center gap-3">
        {plugin.stats.trendingDelta > 0 && (
          <span class="flex items-center gap-1 text-green-400" title="Downloads this week">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            +{formatNumber(plugin.stats.trendingDelta)}
          </span>
        )}
        <span class="bg-white/5 px-2 py-1 rounded text-white/70">
          {category}
        </span>
      </div>
    </div>
  </div>
</a>
