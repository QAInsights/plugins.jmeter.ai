---
---
<div id="installBar" class="fixed bottom-8 right-8 z-[60] transform transition-all duration-500 translate-y-32 hidden">
    <div class="bg-gray-900/90 dark:bg-dark-surface/90 backdrop-blur-xl border border-white/10 shadow-2xl rounded-2xl p-4 flex flex-col gap-3 min-w-[320px] max-w-[400px]">
        <div class="flex items-center justify-between border-b border-white/10 pb-2">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-green-500/20 flex items-center justify-center border border-green-500/30 text-green-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                </div>
                <div>
                    <p class="text-white font-bold text-sm">Install Plugins</p>
                    <p id="installCount" class="text-gray-400 text-[10px] uppercase font-bold tracking-widest">0 selected</p>
                </div>
            </div>
            <button id="clearInstall" class="text-gray-400 hover:text-white transition-colors text-[10px] font-bold uppercase tracking-widest p-1">
                Clear
            </button>
        </div>

        <div class="bg-black/50 rounded-lg p-3 relative group">
            <div class="font-mono text-xs text-green-400 break-all pr-8 h-12 overflow-y-auto" id="installCmdText">
                PluginsManagerCMD.sh install
            </div>
            <button id="copyInstallCmd" class="absolute top-2 right-2 p-1.5 bg-white/10 hover:bg-white/20 rounded text-white transition-colors" title="Copy Command">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
            </button>
        </div>
    </div>
</div>

<script is:inline>
    (function() {
        let installIds = [];

        try {
            installIds = JSON.parse(localStorage.getItem('installIds') || '[]');
        } catch (e) {
            installIds = [];
        }

        function detectCmdName() {
            try {
                const uaData = navigator.userAgentData;
                if (uaData && uaData.platform) {
                    if (/windows/i.test(uaData.platform)) return 'PluginsManagerCMD.bat';
                }
            } catch (e) { /* ignore */ }
            const ua = (navigator.userAgent || '') + ' ' + (navigator.platform || '');
            if (/win/i.test(ua) && !/darwin|mac/i.test(ua)) return 'PluginsManagerCMD.bat';
            return 'PluginsManagerCMD.sh';
        }

        const CMD_NAME = detectCmdName();

        function updateInstallUI() {
            const bar = document.getElementById('installBar');
            const countEl = document.getElementById('installCount');
            const cmdText = document.getElementById('installCmdText');

            if (installIds.length > 0) {
                if (bar) {
                    bar.classList.remove('hidden');
                    setTimeout(() => bar.classList.remove('translate-y-32'), 10);
                }
            } else {
                if (bar) {
                    bar.classList.add('translate-y-32');
                    setTimeout(() => bar.classList.add('hidden'), 500);
                }
            }

            if (countEl) countEl.textContent = `${installIds.length} selected`;
            if (cmdText) cmdText.textContent = `${CMD_NAME} install ${installIds.join(',')}`;

            // Update all install buttons on the page
            document.querySelectorAll('.install-add-btn').forEach(btn => {
                const id = btn.getAttribute('data-plugin-id');
                const isSelected = installIds.includes(id);

                if (isSelected) {
                    btn.classList.add('bg-green-500/20', 'text-green-600', 'dark:text-green-400', 'border-green-500/30');
                    btn.classList.remove('bg-gray-100', 'dark:bg-white/5', 'text-gray-500');
                    if (btn.querySelector('span')) btn.querySelector('span').textContent = 'Added';
                } else {
                    btn.classList.remove('bg-green-500/20', 'text-green-600', 'dark:text-green-400', 'border-green-500/30');
                    btn.classList.add('bg-gray-100', 'dark:bg-white/5', 'text-gray-500');
                    if (btn.querySelector('span')) btn.querySelector('span').textContent = 'Install';
                }
            });
        }

        function toggleInstallPlugin(id) {
            const index = installIds.indexOf(id);
            if (index > -1) {
                installIds.splice(index, 1);
            } else {
                installIds.push(id);
            }
            localStorage.setItem('installIds', JSON.stringify(installIds));
            updateInstallUI();
        }

        // Global event listener for install buttons.
        // Use CAPTURE phase so we run before inline onclick="event.stopPropagation()"
        // on .install-add-btn inside cards (otherwise bubble-phase handler never fires).
        document.addEventListener('click', (e) => {
            const btn = e.target.closest && e.target.closest('.install-add-btn');
            if (btn) {
                e.preventDefault();
                const id = btn.getAttribute('data-plugin-id');
                if (id) {
                    toggleInstallPlugin(id);
                }
                return;
            }

            if (e.target.id === 'clearInstall') {
                installIds = [];
                localStorage.setItem('installIds', JSON.stringify(installIds));
                updateInstallUI();
                return;
            }

            const copyBtn = e.target.closest && e.target.closest('#copyInstallCmd');
            if (copyBtn) {
                const cmdText = document.getElementById('installCmdText').textContent;
                navigator.clipboard.writeText(cmdText).then(() => {
                    const originalHtml = copyBtn.innerHTML;
                    copyBtn.innerHTML = `<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>`;
                    setTimeout(() => { copyBtn.innerHTML = originalHtml; }, 2000);
                });
            }
        }, true);

        // Initialize on load and after Astro navigation
        window.addEventListener('load', updateInstallUI);
        document.addEventListener('astro:after-swap', updateInstallUI);
        document.addEventListener('plugin:install-update', updateInstallUI);

        // Keep the floating bar visible when <dialog> modals are opened.
        // Native dialog.showModal() promotes the dialog to the top layer which
        // visually hides any fixed-position elements outside it. Move the
        // install bar into the open dialog so it joins the top layer too.
        function relocateBarForModal() {
            const bar = document.getElementById('installBar');
            if (!bar) return;
            const openDialog = document.querySelector('dialog[open]');
            if (openDialog) {
                if (bar.parentElement !== openDialog) {
                    openDialog.appendChild(bar);
                }
            } else if (bar.parentElement !== document.body) {
                // Always restore to body when no dialog is open — never leave
                // the bar stranded inside a closed dialog.
                document.body.appendChild(bar);
            }
        }

        // Observe every dialog for `open` attribute changes (covers both
        // showModal() and close()). This is more reliable than listening to
        // the modal's custom event, which fires before showModal() is called.
        function observeDialogs() {
            document.querySelectorAll('dialog').forEach(dlg => {
                if (dlg.__installBarObserved) return;
                dlg.__installBarObserved = true;
                const mo = new MutationObserver(relocateBarForModal);
                mo.observe(dlg, { attributes: true, attributeFilter: ['open'] });
            });
        }
        observeDialogs();
        document.addEventListener('astro:after-swap', observeDialogs);
        // Also keep listening for install-update (in case DOM added dialogs late)
        document.addEventListener('plugin:install-update', () => {
            observeDialogs();
            relocateBarForModal();
        });

        // Expose to cards that might be rendered dynamically
        window.refreshInstallUI = updateInstallUI;
    })();
</script>
