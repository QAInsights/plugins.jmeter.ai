---
---
<button
    id="scrollToTopBtn"
    class="fixed bottom-8 right-8 z-[90] p-3 rounded-full bg-primary/90 text-dark-bg shadow-lg shadow-primary/20 backdrop-blur hover:bg-primary transition-all duration-300 translate-y-20 opacity-0 focus:outline-none pointer-events-none"
    aria-label="Scroll to top"
>
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
</button>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('scrollToTopBtn');
        if (!btn) return;

        // Show/hide based on scroll position
        window.addEventListener('scroll', () => {
            if (window.scrollY > 400) {
                btn.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
                btn.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
            } else {
                btn.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
                btn.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
            }
        });

        // Scroll to top action
        btn.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
    });
</script>
