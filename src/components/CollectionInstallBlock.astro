---
interface Props {
  pluginIds: string[];
  collectionName: string;
}

const { pluginIds, collectionName } = Astro.props;
const installArg = pluginIds.join(',');
---

<div class="bg-gray-950 dark:bg-black/60 border border-white/10 rounded-2xl overflow-hidden">
  <div class="flex items-center justify-between px-5 py-3 border-b border-white/10">
    <div class="flex items-center gap-2">
      <div class="w-2.5 h-2.5 rounded-full bg-red-500/70"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-green-500/70"></div>
    </div>
    <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500">Terminal</span>
    <div></div>
  </div>

  <div class="p-5 relative">
    <pre class="font-mono text-sm text-green-400 whitespace-pre-wrap break-all leading-relaxed" id="collectionInstallCmd"><span class="text-gray-500">$ </span><span id="collectionCmdText">PluginsManagerCMD.sh install {installArg}</span></pre>

    <div class="flex flex-col sm:flex-row gap-3 mt-5">
      <button
        id="copyCollectionCmd"
        type="button"
        class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-white/10 hover:bg-white/20 text-white font-semibold text-sm transition-colors border border-white/10 hover:border-white/20"
        data-cmd={installArg}
        aria-label="Copy install command"
      >
        <svg class="w-4 h-4" id="copyIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
        </svg>
        <span id="copyBtnLabel">Copy Command</span>
      </button>

      <button
        id="installStackBtn"
        type="button"
        class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-primary hover:bg-primary/90 text-gray-900 font-bold text-sm transition-all shadow-lg shadow-primary/20 hover:shadow-primary/40"
        data-plugin-ids={installArg}
        aria-label={`Add entire ${collectionName} to install list`}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
        </svg>
        <span>Install entire stack</span>
      </button>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  function detectCmdName() {
    try {
      const uaData = navigator.userAgentData;
      if (uaData && uaData.platform) {
        if (/windows/i.test(uaData.platform)) return 'PluginsManagerCMD.bat';
      }
    } catch (e) { /* ignore */ }
    const ua = (navigator.userAgent || '') + ' ' + (navigator.platform || '');
    if (/win/i.test(ua) && !/darwin|mac/i.test(ua)) return 'PluginsManagerCMD.bat';
    return 'PluginsManagerCMD.sh';
  }

  function init() {
    const cmdText = document.getElementById('collectionCmdText');
    const copyBtn = document.getElementById('copyCollectionCmd');
    const installBtn = document.getElementById('installStackBtn');

    if (!cmdText || !copyBtn || !installBtn) return;

    const cmdName = detectCmdName();
    const installArg = copyBtn.getAttribute('data-cmd') || '';
    const fullCmd = cmdName + ' install ' + installArg;

    cmdText.textContent = fullCmd;

    copyBtn.addEventListener('click', function () {
      navigator.clipboard.writeText(fullCmd).then(function () {
        const label = document.getElementById('copyBtnLabel');
        const icon = document.getElementById('copyIcon');
        if (label) label.textContent = 'Copied!';
        if (icon) icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>';
        setTimeout(function () {
          if (label) label.textContent = 'Copy Command';
          if (icon) icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>';
        }, 2000);
      }).catch(function () { /* clipboard unavailable */ });
    });

    installBtn.addEventListener('click', function () {
      var ids;
      try {
        ids = JSON.parse(localStorage.getItem('installIds') || '[]');
      } catch (e) {
        ids = [];
      }
      var newIds = (installArg || '').split(',').filter(Boolean);
      newIds.forEach(function (id) {
        if (!ids.includes(id)) ids.push(id);
      });
      localStorage.setItem('installIds', JSON.stringify(ids));
      document.dispatchEvent(new Event('plugin:install-update'));

      installBtn.classList.add('bg-green-500', 'shadow-green-500/20');
      installBtn.classList.remove('bg-primary', 'shadow-primary/20', 'hover:shadow-primary/40');
      var span = installBtn.querySelector('span');
      var svg = installBtn.querySelector('svg');
      if (span) span.textContent = 'Added to install list';
      if (svg) svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
})();
</script>
