---
/**
 * UserMenu Component
 * 
 * Displays user avatar and dropdown menu for authenticated users.
 */

import { SignOutButton } from '@clerk/astro/components';
---

<div class="user-menu relative">
    <button 
        class="menu-trigger flex items-center gap-2 p-1 pr-3 rounded-full bg-gray-100 dark:bg-dark-surface border border-gray-200 dark:border-white/10 hover:bg-gray-200 dark:hover:bg-white/10 transition-colors"
    >
        <img 
            class="user-avatar w-7 h-7 rounded-full bg-gray-300" 
            src="" 
            alt="User avatar"
        />
        <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
    </button>

    {/* Custom Dropdown */}
    <div class="dropdown hidden absolute right-0 mt-2 w-48 rounded-lg bg-white dark:bg-dark-surface border border-gray-200 dark:border-white/10 shadow-lg py-1 z-50">
        <div class="user-info px-4 py-2 border-b border-gray-100 dark:border-white/5">
            <p class="user-name text-sm font-semibold text-gray-900 dark:text-white truncate"></p>
            <p class="user-email text-xs text-gray-500 dark:text-gray-400 truncate"></p>
        </div>
        <a 
            href="/settings" 
            class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors"
        >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Settings
        </a>
        <SignOutButton asChild>
            <button 
                class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-gray-100 dark:hover:bg-white/5 transition-colors text-left"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Sign Out
            </button>
        </SignOutButton>
    </div>
</div>

<script>
    import { $userStore } from '@clerk/astro/client';

    const userMenu = document.querySelector('.user-menu');
    const dropdown = userMenu?.querySelector('.dropdown');
    const userAvatar = userMenu?.querySelector('.user-avatar') as HTMLImageElement | null;
    const userName = userMenu?.querySelector('.user-name');
    const userEmail = userMenu?.querySelector('.user-email');
    const menuButton = userMenu?.querySelector('.menu-trigger');

    // Update user info
    $userStore.subscribe((user) => {
        if (user && userAvatar && userName && userEmail) {
            userAvatar.src = user.imageUrl || '';
            userAvatar.alt = user.fullName || user.username || 'User';
            userName.textContent = user.fullName || user.username || 'User';
            userEmail.textContent = user.primaryEmailAddress?.emailAddress || '';
        }
    });

    // Toggle dropdown
    menuButton?.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle('hidden');
    });

    // Close when clicking outside
    document.addEventListener('click', () => {
        dropdown?.classList.add('hidden');
    });
</script>
